class {{ block_name }}_reg_block extends uvm_reg_block;

    `uvm_object_utils({{ block_name }}_reg_block)

    // ========================================================================
    // Register declarations
    // ========================================================================
{% for reg in registers %}
{% if reg.effective_access == "RW" %}
    rand {{ block_name }}_{{ reg.name }}_reg {{ reg.name }};
{% else %}
    {{ block_name }}_{{ reg.name }}_reg {{ reg.name }};
{% endif %}
{% endfor %}

    // ========================================================================
    // Constructor
    // ========================================================================
