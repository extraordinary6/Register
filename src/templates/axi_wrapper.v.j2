    // ========================================================================
    // Internal signals
    // ========================================================================
    wire [{{ addr_width }}-1:0] core_addr;
    wire [{{ data_width }}-1:0] core_wdata;
    wire        core_wen;
    wire [{{ strb_width }}-1:0] core_wstrb;
    wire        core_ren;
    wire [{{ data_width }}-1:0] core_rdata;
    wire        core_ready;

    // ========================================================================
    // Write Address Channel
    // ========================================================================
    reg  awaddr_sel;
    wire awaddr_done = awvalid && awready;
    assign awready = awvalid && !awaddr_sel;

    always @(posedge aclk or negedge aresetn) begin
        if (!aresetn)
            awaddr_sel <= 1'b0;
        else if (awaddr_done)
            awaddr_sel <= 1'b1;
        else if (core_wen)
            awaddr_sel <= 1'b0;
    end

    // ========================================================================
    // Write Data Channel — accept W when AW is captured and data valid
    // ========================================================================
    reg wdata_sel;
    wire wdata_done = wvalid && wready;
    assign wready = wvalid && awaddr_sel && !wdata_sel;

    always @(posedge aclk or negedge aresetn) begin
        if (!aresetn)
            wdata_sel <= 1'b0;
        else if (wdata_done)
            wdata_sel <= 1'b1;
        else if (core_wen)
            wdata_sel <= 1'b0;
    end

    // ========================================================================
    // Write Response Channel
    // ========================================================================
    reg bvalid_reg;
    assign bvalid = bvalid_reg;
    assign bresp  = 2'b00;

    always @(posedge aclk or negedge aresetn) begin
        if (!aresetn)
            bvalid_reg <= 1'b0;
        else if (core_wen && bvalid_reg == 1'b0)
            bvalid_reg <= 1'b1;
        else if (bvalid && bready)
            bvalid_reg <= 1'b0;
    end

    // ========================================================================
    // Read Address Channel
    // ========================================================================
    reg ar_sel;
    wire ar_done = arvalid && arready;
    assign arready = arvalid && !ar_sel;

    always @(posedge aclk or negedge aresetn) begin
        if (!aresetn)
            ar_sel <= 1'b0;
        else if (ar_done)
            ar_sel <= 1'b1;
        else if (core_ren)
            ar_sel <= 1'b0;
    end

    // ========================================================================
    // Read Data Channel
    // ========================================================================
    reg rvalid_reg;
    reg [{{ data_width - 1 }}:0] rdata_reg;
    assign rvalid = rvalid_reg;
    assign rdata  = rdata_reg;
    assign rresp  = 2'b00;

    always @(posedge aclk or negedge aresetn) begin
        if (!aresetn) begin
            rvalid_reg <= 1'b0;
        end else begin
            if (ar_sel && core_ready && !rvalid_reg) begin
                rvalid_reg <= 1'b1;
                rdata_reg  <= core_rdata;
            end else if (rvalid && rready) begin
                rvalid_reg <= 1'b0;
            end
        end
    end

    // ========================================================================
    // AXI -> Core interface mapping
    // ========================================================================
    assign core_addr  = awaddr[{{ addr_width + byte_addr_lsb - 1 }}:{{ byte_addr_lsb }}];
    assign core_wdata = wdata;
    assign core_wstrb = wstrb;
    assign core_wen   = awaddr_sel && wdata_sel;
    assign core_ren   = ar_sel;

