    {{ module_name }}_regfile_core #(
        .AW({{ addr_width }}),
        .DW({{ data_width }})
    ) u_regfile_core (
{% for _conn in _core_conns %}{{ _conn }}{{ "," if not loop.last else "" }}
{% endfor %}
    );

